{
  "expo": {
    "name": "GIGCCL Attendance",
    "slug": "gigccl-attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pk.edu.gigccl.attendance"
    },
    "android": {
      "package": "pk.edu.gigccl.attendance",
      "adaptiveIcon": {
        "backgroundColor": "#1e40af"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "GIGCCL Attendance needs your location to verify you are on campus."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9fc78f00-667a-43be-90b7-fb490ba7b311"
      }
    },
    "owner": "faizan_mujahid"
  }
}
